{
  "name": "smart-ai",
  "icon": "media/icon.png",
  "author": "Smart AI",
  "version": "1.3.39",
  "repository": {
    "type": "git",
    "url": "https://github.com/tommycrusher/smart-ai"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "bugs": {
    "url": "https://github.com/tommycrusher/smart-ai/issues",
    "email": "support@smart-ai.dev"
  },
  "homepage": "https://smart-ai.dev",
  "qna": "https://github.com/tommycrusher/smart-ai/issues/new/choose",
  "license": "Apache-2.0",
  "displayName": "Smart AI - AI code agent",
  "pricing": "Free",
  "description": "AI code agent for smart development",
  "publisher": "smartbygg",
  "engines": {
    "vscode": "^1.70.0",
    "node": ">=20.20.1"
  },
  "engine-strict": true,
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Machine Learning",
    "Snippets"
  ],
  "keywords": [
    "chatgpt",
    "cline",
    "roo",
    "github",
    "copilot",
    "claude",
    "mistral",
    "codestral",
    "ai"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished",
    "onView:smartai.continueGUIView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "filenames": [
          "config.json",
          ".continuerc.json"
        ],
        "id": "jsonc"
      },
      {
        "id": "promptLanguage",
        "extensions": [
          ".prompt"
        ],
        "aliases": [
          "Prompt Language"
        ],
        "configuration": "./prompt-file-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "promptLanguage",
        "scopeName": "source.prompt",
        "path": "./media/prompt.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Smart AI",
      "properties": {
        "smartai.telemetryEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Smart AI collects anonymous usage data, cleaned of PII, to help us improve the product for our users. Read more  at [smart-ai.dev › Telemetry](https://docs.smart-ai.dev/telemetry).",
          "markdownDeprecationMessage": "This setting is deprecated and will be removed in a later version. Please use the _Telemetry > Allow Anonymous Telemetry_ setting in the extension's User Settings page.",
          "deprecationMessage": "Please use the _Telemetry > Allow Anonymous Telemetry_ setting in the extension's User Settings page."
        },
        "smartai.showInlineTip": {
          "type": "boolean",
          "default": true,
          "description": "Show inline suggestion to use the Smart AI keyboard shortcuts (e.g. \"Cmd/Ctrl L to chat, Cmd/Ctrl I to edit\")."
        },
        "smartai.disableQuickFix": {
          "type": "boolean",
          "default": false,
          "description": "Disable the quick fix feature."
        },
        "smartai.enableQuickActions": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable the experimental Quick Actions feature. Read our walkthrough to learn about configuration and how to share feedback: [smart-ai.dev › Walkthrough: Quick Actions (experimental)](https://docs.smart-ai.dev/customize/deep-dives/vscode-actions#quick-actions)"
        },
        "smartai.enableTabAutocomplete": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable Smart AI's tab autocomplete feature. Read our walkthrough to learn about configuration and how to share feedback: [smart-ai.dev › Walkthrough: Tab Autocomplete (beta)](https://docs.smart-ai.dev/features/tab-autocomplete)"
        },
        "smartai.enableNextEdit": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable Smart AI's next edit feature. Read our docs to learn about configuration and how to share feedback: [smart-ai.dev › Features › Autocomplete › Next Edit (experimental)](https://docs.smart-ai.dev/features/autocomplete/next-edit)"
        },
        "smartai.pauseTabAutocompleteOnBattery": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Pause Smart AI's tab autocomplete feature when your battery is low."
        },
        "smartai.pauseCodebaseIndexOnStart": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Pause Smart AI's codebase index on start."
        },
        "smartai.enableConsole": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable a console to log and explore model inputs and outputs. It can be found in the bottom panel."
        },
        "smartai.remoteConfigServerUrl": {
          "type": "string",
          "default": null,
          "markdownDescription": "If your team is set up to use shared configuration, enter the server URL here and your user token below to enable automatic syncing."
        },
        "smartai.userToken": {
          "type": "string",
          "default": null,
          "markdownDescription": "If your team is set up to use shared configuration, enter your user token here and your server URL above to enable automatic syncing."
        },
        "smartai.remoteConfigSyncPeriod": {
          "type": "number",
          "default": 60,
          "description": "The period of time in minutes between automatic syncs."
        },
        "smartai.trainingCaptureEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic training data capture from Smart AI interactions. Stores structured examples for later model fine-tuning."
        },
        "smartai.trainingAutoCaptureAccepted": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture accepted edits/applies as training examples."
        },
        "smartai.trainingAutoCaptureChat": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture chat outputs as training examples."
        },
        "smartai.trainingAutoCaptureEditApply": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture edit and apply operations as training examples."
        },
        "smartai.trainingAutoCaptureAgent": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture agent mode outputs as training examples."
        },
        "smartai.trainingMaxPatchSize": {
          "type": "number",
          "default": 500000,
          "description": "Maximum patch size in bytes to store for training data."
        },
        "smartai.trainingMaxResponseSize": {
          "type": "number",
          "default": 100000,
          "description": "Maximum response size in bytes to capture as training data."
        },
        "smartai.trainingSmarterpOnly": {
          "type": "boolean",
          "default": false,
          "description": "Only capture training data when working in a Smarterp repository."
        },
        "smartai.trainingDatasetPath": {
          "type": "string",
          "default": null,
          "description": "Custom path for the training dataset JSONL file. Defaults to ~/.smart-ai/training/train.jsonl."
        },
        "smartai.trainingEvalPath": {
          "type": "string",
          "default": null,
          "description": "Custom path for the evaluation dataset JSONL file. Defaults to ~/.smart-ai/training/eval.jsonl."
        },
        "smartai.trainingPatchDirPath": {
          "type": "string",
          "default": null,
          "description": "Custom path for storing training patch files. Defaults to ~/.smart-ai/training/patches."
        },
        "smartai.trainingExportDirPath": {
          "type": "string",
          "default": null,
          "description": "Custom path for exported training bundles. Defaults to ~/.smart-ai/training/exports."
        },
        "smartai.trainingTempDirPath": {
          "type": "string",
          "default": null,
          "description": "Optional temp directory for staging files during export. Defaults to ~/.smart-ai/training/temp."
        },
        "smartai.trainingRuntimeMode": {
          "type": "string",
          "enum": [
            "local",
            "remote-host"
          ],
          "default": "local",
          "description": "Runtime mode for training data capture. 'local' for direct IDE usage, 'remote-host' for SSH tunnel / remote extension host setups."
        },
        "smartai.trainingOllamaApiBase": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API base URL to record in training metadata. Use http://localhost:11435 for remote tunnel mode."
        },
        "smartai.modelProfile": {
          "type": "string",
          "enum": [
            "local-balanced",
            "local-pro",
            "local-reasoning",
            "cloud-kimi-k2.6",
            "cloud-glm-5.1",
            "cloud-minimax-m3",
            "cloud-deepseek-v4"
          ],
          "default": "local-balanced",
          "description": "Active model profile. Default profiles are fully non-pay and local. Optional cloud profiles require explicit opt-in and external API credentials."
        }
      }
    },
    "commands": [
      {
        "command": "smartai.applyCodeFromChat",
        "category": "Smart AI",
        "title": "Apply code from chat",
        "group": "Smart AI"
      },
      {
        "command": "smartai.acceptDiff",
        "category": "Smart AI",
        "title": "Accept Diff",
        "group": "Smart AI"
      },
      {
        "command": "smartai.rejectDiff",
        "category": "Smart AI",
        "title": "Reject Diff",
        "group": "Smart AI",
        "icon": "$(stop)"
      },
      {
        "command": "smartai.acceptVerticalDiffBlock",
        "category": "Smart AI",
        "title": "Accept Vertical Diff Block",
        "group": "Smart AI"
      },
      {
        "command": "smartai.rejectVerticalDiffBlock",
        "category": "Smart AI",
        "title": "Reject Vertical Diff Block",
        "group": "Smart AI"
      },
      {
        "command": "smartai.focusEdit",
        "category": "Smart AI",
        "title": "Add to Edit",
        "group": "Smart AI"
      },
      {
        "command": "smartai.focusContinueInput",
        "category": "Smart AI",
        "title": "Add Highlighted Code to Context and Clear Chat",
        "group": "Smart AI"
      },
      {
        "command": "smartai.focusContinueInputWithoutClear",
        "category": "Smart AI",
        "title": "Add to Chat",
        "group": "Smart AI"
      },
      {
        "command": "smartai.debugTerminal",
        "category": "Smart AI",
        "title": "Debug Terminal",
        "group": "Smart AI"
      },
      {
        "command": "smartai.exitEditMode",
        "category": "Smart AI",
        "title": "Exit Edit Mode",
        "group": "Smart AI"
      },
      {
        "command": "smartai.openConfigPage",
        "category": "Smart AI",
        "title": "Open Settings",
        "icon": "$(gear)",
        "group": "Smart AI"
      },
      {
        "command": "smartai.toggleTabAutocompleteEnabled",
        "category": "Smart AI",
        "title": "Toggle Autocomplete Enabled",
        "group": "Smart AI"
      },
      {
        "command": "smartai.forceAutocomplete",
        "title": "Smart AI: Force Autocomplete",
        "category": "Smart AI"
      },
      {
        "command": "smartai.selectFilesAsContext",
        "category": "Smart AI",
        "title": "Select Files as Context",
        "group": "Smart AI"
      },
      {
        "command": "smartai.newSession",
        "category": "Smart AI",
        "title": "New Session",
        "icon": "$(add)",
        "group": "Smart AI"
      },
      {
        "command": "smartai.shareSession",
        "category": "Smart AI",
        "title": "Share Current Chat Session as Markdown",
        "group": "Smart AI"
      },
      {
        "command": "smartai.viewHistory",
        "category": "Smart AI",
        "title": "View History",
        "icon": "$(history)",
        "group": "Smart AI"
      },
      {
        "command": "smartai.viewLogs",
        "category": "Smart AI",
        "title": "View Logs",
        "group": "Smart AI"
      },
      {
        "command": "smartai.clearConsole",
        "category": "Smart AI",
        "title": "Clear Console",
        "icon": "$(clear-all)",
        "group": "Smart AI"
      },
      {
        "command": "smartai.navigateTo",
        "category": "Smart AI",
        "title": "Navigate to a path",
        "group": "Smart AI"
      },
      {
        "command": "smartai.writeCommentsForCode",
        "category": "Smart AI",
        "title": "Write Comments for this Code",
        "group": "Smart AI"
      },
      {
        "command": "smartai.writeDocstringForCode",
        "category": "Smart AI",
        "title": "Write a Docstring for this Code",
        "group": "Smart AI"
      },
      {
        "command": "smartai.fixCode",
        "category": "Smart AI",
        "title": "Fix this Code",
        "group": "Smart AI"
      },
      {
        "command": "smartai.optimizeCode",
        "category": "Smart AI",
        "title": "Optimize this Code",
        "group": "Smart AI"
      },
      {
        "command": "smartai.fixGrammar",
        "category": "Smart AI",
        "title": "Fix Grammar / Spelling",
        "group": "Smart AI"
      },
      {
        "command": "smartai.codebaseForceReIndex",
        "category": "Smart AI",
        "title": "Codebase Force Re-Index",
        "group": "Smart AI"
      },
      {
        "command": "smartai.rebuildCodebaseIndex",
        "category": "Smart AI",
        "title": "Rebuild codebase index",
        "group": "Smart AI"
      },
      {
        "command": "smartai.docsIndex",
        "category": "Smart AI",
        "title": "Docs Index",
        "group": "Smart AI"
      },
      {
        "command": "smartai.docsReIndex",
        "category": "Smart AI",
        "title": "Docs Force Re-Index",
        "group": "Smart AI"
      },
      {
        "command": "smartai.focusContinueInput",
        "category": "Smart AI",
        "title": "Focus Smart AI Chat",
        "group": "Smart AI"
      },
      {
        "command": "smartai.enterEnterpriseLicenseKey",
        "category": "Smart AI",
        "title": "Enter Enterprise License Key",
        "group": "Smart AI"
      },
      {
        "command": "smartai.toggleNextEditEnabled",
        "title": "Smart AI: Toggle Next Edit"
      },
      {
        "command": "smartai.nextEditWindow.hideNextEditSuggestion",
        "category": "Smart AI",
        "title": "Hide Next Edit Suggestion"
      },
      {
        "command": "smartai.nextEditWindow.acceptNextEditSuggestion",
        "category": "Smart AI",
        "title": "Accept Next Edit Suggestion"
      },
      {
        "command": "smartai.forceNextEdit",
        "category": "Smart AI",
        "title": "Smart AI: Force Next Edit"
      },
      {
        "command": "smartai.acceptJump",
        "category": "Smart AI",
        "title": "Smart AI: Accept Jump Suggestion"
      },
      {
        "command": "smartai.rejectJump",
        "category": "Smart AI",
        "title": "Smart AI: Reject Jump Suggestion"
      },
      {
        "command": "smartai.generateRule",
        "category": "Smart AI",
        "title": "Generate Rule",
        "group": "Smart AI"
      },
      {
        "command": "smartai.openInNewWindow",
        "category": "Smart AI",
        "title": "Open in new window",
        "group": "Smart AI"
      },
      {
        "command": "smartai.toggleTrainingCapture",
        "category": "Smart AI",
        "title": "Toggle Training Capture",
        "group": "Smart AI Training"
      },
      {
        "command": "smartai.saveLastExchange",
        "category": "Smart AI",
        "title": "Save Last Exchange as Training Example",
        "group": "Smart AI Training"
      },
      {
        "command": "smartai.saveLastPatch",
        "category": "Smart AI",
        "title": "Save Last Patch as Training Example",
        "group": "Smart AI Training"
      },
      {
        "command": "smartai.exportTrainingBundle",
        "category": "Smart AI",
        "title": "Export Training Bundle",
        "group": "Smart AI Training"
      },
      {
        "command": "smartai.openTrainingFolder",
        "category": "Smart AI",
        "title": "Open Training Storage Folder",
        "group": "Smart AI Training"
      },
      {
        "command": "smartai.markHighQuality",
        "category": "Smart AI",
        "title": "Mark Last Response as High Quality",
        "group": "Smart AI Training"
      },
      {
        "command": "smartai.markReject",
        "category": "Smart AI",
        "title": "Mark Last Response as Reject / Do Not Train",
        "group": "Smart AI Training"
      }
    ],
    "keybindings": [
      {
        "command": "smartai.focusContinueInput",
        "mac": "cmd+l",
        "key": "ctrl+l"
      },
      {
        "command": "smartai.focusContinueInputWithoutClear",
        "mac": "cmd+shift+l",
        "key": "ctrl+shift+l"
      },
      {
        "command": "smartai.acceptDiff",
        "mac": "shift+cmd+enter",
        "key": "shift+ctrl+enter",
        "when": "smartai.diffVisible"
      },
      {
        "command": "smartai.rejectDiff",
        "mac": "shift+cmd+backspace",
        "key": "shift+ctrl+backspace",
        "when": "smartai.diffVisible"
      },
      {
        "command": "smartai.rejectDiff",
        "mac": "cmd+z",
        "key": "ctrl+z",
        "when": "smartai.diffVisible"
      },
      {
        "command": "smartai.quickEditHistoryUp",
        "mac": "up",
        "key": "up",
        "when": "false && smartai.quickEditHistoryFocused"
      },
      {
        "command": "smartai.quickEditHistoryDown",
        "mac": "down",
        "key": "down",
        "when": "false && smartai.quickEditHistoryFocused"
      },
      {
        "command": "smartai.acceptVerticalDiffBlock",
        "mac": "alt+cmd+y",
        "key": "alt+ctrl+y"
      },
      {
        "command": "smartai.rejectVerticalDiffBlock",
        "mac": "alt+cmd+n",
        "key": "alt+ctrl+n"
      },
      {
        "command": "smartai.focusEdit",
        "title": "Edit code with natural language",
        "mac": "cmd+i",
        "key": "ctrl+i"
      },
      {
        "command": "smartai.exitEditMode",
        "mac": "escape",
        "key": "escape",
        "when": "smartai.inEditMode && editorFocus"
      },
      {
        "command": "smartai.debugTerminal",
        "mac": "cmd+shift+r",
        "key": "ctrl+shift+r"
      },
      {
        "command": "smartai.openInNewWindow",
        "mac": "cmd+k cmd+m",
        "key": "ctrl+k ctrl+m",
        "when": "!terminalFocus"
      },
      {
        "command": "smartai.toggleTabAutocompleteEnabled",
        "mac": "cmd+k cmd+a",
        "key": "ctrl+k ctrl+a",
        "when": "!terminalFocus"
      },
      {
        "command": "smartai.forceAutocomplete",
        "key": "ctrl+alt+space",
        "mac": "cmd+alt+space",
        "when": "editorTextFocus && !editorHasSelection && !editorReadOnly && !inSnippetMode"
      },
      {
        "command": "smartai.applyCodeFromChat",
        "mac": "alt+a",
        "key": "alt+a"
      },
      {
        "command": "smartai.toggleNextEditEnabled",
        "key": "ctrl+k ctrl+n",
        "mac": "cmd+k cmd+n",
        "when": "editorTextFocus"
      },
      {
        "command": "smartai.nextEditWindow.hideNextEditSuggestion",
        "key": "escape",
        "when": "editorTextFocus && nextEditWindowActive && !smartai.jumpDecorationVisible"
      },
      {
        "command": "smartai.nextEditWindow.acceptNextEditSuggestion",
        "key": "tab",
        "when": "editorTextFocus && nextEditWindowActive && !smartai.jumpDecorationVisible"
      },
      {
        "command": "smartai.acceptJump",
        "key": "tab",
        "when": "editorTextFocus && smartai.jumpDecorationVisible"
      },
      {
        "command": "smartai.rejectJump",
        "key": "escape",
        "when": "editorTextFocus && smartai.jumpDecorationVisible"
      }
    ],
    "submenus": [
      {
        "id": "smartai.continueSubMenu",
        "label": "Smart AI"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "smartai.focusContinueInput"
        },
        {
          "command": "smartai.focusContinueInputWithoutClear"
        },
        {
          "command": "smartai.debugTerminal"
        },
        {
          "command": "smartai.newSession"
        },
        {
          "command": "smartai.enterEnterpriseLicenseKey"
        },
        {
          "command": "smartai.generateRule"
        },
        {
          "command": "smartai.openInNewWindow"
        },
        {
          "command": "smartai.toggleTrainingCapture"
        },
        {
          "command": "smartai.saveLastExchange"
        },
        {
          "command": "smartai.saveLastPatch"
        },
        {
          "command": "smartai.exportTrainingBundle"
        },
        {
          "command": "smartai.openTrainingFolder"
        },
        {
          "command": "smartai.markHighQuality"
        },
        {
          "command": "smartai.markReject"
        }
      ],
      "editor/context": [
        {
          "submenu": "smartai.continueSubMenu",
          "group": "0_acontinue"
        }
      ],
      "editor/title/run": [
        {
          "command": "smartai.rejectDiff",
          "group": "Smart AI",
          "when": "smartai.streamingDiff"
        }
      ],
      "smartai.continueSubMenu": [
        {
          "command": "smartai.focusContinueInputWithoutClear",
          "group": "Smart AI"
        },
        {
          "command": "smartai.focusEdit",
          "group": "Smart AI",
          "when": "!editorReadonly"
        }
      ],
      "explorer/context": [
        {
          "command": "smartai.selectFilesAsContext",
          "group": "1_debug@1"
        }
      ],
      "view/title": [
        {
          "command": "smartai.newSession",
          "group": "navigation@1",
          "when": "view == smartai.continueGUIView"
        },
        {
          "command": "smartai.viewHistory",
          "group": "navigation@2",
          "when": "view == smartai.continueGUIView"
        },
        {
          "command": "smartai.openConfigPage",
          "group": "navigation@4",
          "when": "view == smartai.continueGUIView"
        },
        {
          "command": "smartai.clearConsole",
          "group": "navigation@1",
          "when": "view == smartai.continueConsoleView"
        }
      ],
      "editor/title": [
        {
          "command": "smartai.newSession",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == smartai.continueGUIView"
        },
        {
          "command": "smartai.viewHistory",
          "group": "navigation@2",
          "when": "activeWebviewPanelId == smartai.continueGUIView"
        }
      ],
      "terminal/context": [
        {
          "command": "smartai.debugTerminal",
          "group": "navigation@top"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "smartai",
          "title": "Smart AI",
          "icon": "media/sidebar-icon.png"
        }
      ],
      "panel": [
        {
          "id": "smartaiConsole",
          "title": "Smart AI Console",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "smartai": [
        {
          "type": "webview",
          "id": "smartai.continueGUIView",
          "name": "Smart AI",
          "icon": "media/sidebar-icon.png",
          "visibility": "visible"
        }
      ],
      "smartaiConsole": [
        {
          "type": "webview",
          "id": "smartai.continueConsoleView",
          "name": "Smart AI Console",
          "icon": "$(window)",
          "visibility": "visible",
          "when": "config.smartai.enableConsole"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.continue*/config.json",
        "url": "./config_schema.json"
      },
      {
        "fileMatch": ".continuerc.json",
        "url": "./continue_rc_schema.json"
      },
      {
        "fileMatch": "**/config.yaml",
        "url": "./config-yaml-schema.json"
      }
    ]
  },
  "scripts": {
    "esbuild-base": "node scripts/esbuild.js",
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "esbuild-notify": "npm run esbuild-base -- --sourcemap --notify",
    "esbuild:visualize": "esbuild-visualizer --metadata ./build/meta.json --filename ./build/stats.html --open",
    "tsc": "tsc -p ./",
    "tsc:check": "tsc -p ./ --noEmit",
    "tsc-watch": "tsc -watch -p ./",
    "rebuild": "electron-rebuild -v 19.1.8 node-pty",
