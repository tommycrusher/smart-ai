# Smart AI - Ollama Configuration Template
#
# This is a template configuration for Smart AI with Ollama provider.
# Use this to set up your local development environment with Ollama models.
#
# To use this configuration:
# 1. Copy to: ~/.continue/config.yaml or PROJECT_DIR/.continue/config.yaml
# 2. Ensure Ollama is running with the specified models
# 3. To switch between local/remote mode, set SMARTAI_OLLAMA_MODE=local|remote
#
# Model Setup:
# - Chat/Edit/Apply: smarterp-coder (custom model)
#   Fallback: qwen2.5-coder:7b (run: ollama pull qwen2.5-coder:7b)
# - Autocomplete: qwen2.5-coder:1.5b (run: ollama pull qwen2.5-coder:1.5b)
# - Embeddings: nomic-embed-text (run: ollama pull nomic-embed-text)
#
# Mode Switching (no file edits required):
# - Local mode (default):  export SMARTAI_OLLAMA_MODE=local  -> http://localhost:11434
# - Remote tunnel mode:    export SMARTAI_OLLAMA_MODE=remote -> http://localhost:11435

name: "Smart AI - Ollama"
version: "1.0.0"
schema: "v1"

# Models configuration
models:
  # Primary chat/code model (chat, edit, apply roles)
  - name: "Smart AI Coder"
    provider: "ollama"
    model: "smarterp-coder"
    roles:
      - chat
      - edit
      - apply
    defaultCompletionOptions:
      temperature: 0.3
      maxTokens: 4096
      topP: 0.9
      topK: 20
    chatOptions:
      baseSystemMessage: "You are Smart AI, a practical coding assistant. Write clean, modern code following the project's existing conventions. Prefer minimal, targeted changes. Explain reasoning briefly when asked, but default to concise answers."

  # Fallback chat model (if smarterp-coder not available)
  - name: "Qwen2.5-Coder 7B"
    provider: "ollama"
    model: "qwen2.5-coder:7b"
    roles:
      - chat
      - edit
      - apply
    defaultCompletionOptions:
      temperature: 0.3
      maxTokens: 4096
      topP: 0.9
      topK: 20
    chatOptions:
      baseSystemMessage: "You are Smart AI, a practical coding assistant. Write clean, modern code following the project's existing conventions. Prefer minimal, targeted changes. Explain reasoning briefly when asked, but default to concise answers."

  # Tab autocomplete model (lightweight FIM)
  - name: "Qwen2.5-Coder 1.5B (Autocomplete)"
    provider: "ollama"
    model: "qwen2.5-coder:1.5b"
    roles:
      - autocomplete
    defaultCompletionOptions:
      temperature: 0.2
      maxTokens: 256
      topP: 0.9

  # Embedding model for context retrieval
  - name: "Nomic Embed"
    provider: "ollama"
    model: "nomic-embed-text"
    roles:
      - embed

# Context providers - Copilot-style repo and file awareness
context:
  - provider: "file"
  - provider: "currentFile"
  - provider: "open"
  - provider: "codebase"
  - provider: "folder"
  - provider: "diff"
  - provider: "terminal"
  - provider: "problems"
  - provider: "rules"
  - provider: "docs"

# Always-active rules (Copilot-style behavior)
rules:
  - name: "Smart AI Copilot Behavior"
    rule: "You are Smart AI, a practical coding assistant. Write clean, modern code following the project's existing conventions. Prefer minimal, targeted changes. Explain reasoning briefly when asked, but default to concise answers. When editing code, preserve existing style and formatting."
    alwaysApply: true

# Tab autocomplete configuration
tabAutocompleteOptions:
  disable: false
  maxPromptTokens: 1024
  debounceDelay: 300
  maxSuffixPercentage: 0.2
  prefixPercentage: 0.5
  useCache: true

# UI Configuration
ui:
  codeBlockToolbarPosition: "top"
  displayRawMarkdown: false
  showChatScrollbar: true
  codeWrap: true

# Analytics (disabled for private Smart AI)
analytics:
  provider: "null"

# Model roles (experimental)
experimental:
  modelRoles:
    inlineEdit: "Smart AI Coder"
    applyCodeBlock: "Smart AI Coder"
    repoMapFileSelection: "Smart AI Coder"
