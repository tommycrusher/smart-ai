{
  "name": "Smart AI - Ollama Local",
  "version": "1.0.0",
  "schema": "v1",
  "models": [
    {
      "title": "Smart AI Coder",
      "provider": "ollama",
      "model": "smarterp-coder",
      "apiBase": "http://localhost:11434",
      "completionOptions": {
        "temperature": 0.3,
        "maxTokens": 4096,
        "topP": 0.9,
        "topK": 20
      },
      "systemMessage": "You are Smart AI, a practical coding assistant. Write clean, modern code following the project's existing conventions. Prefer minimal, targeted changes. Explain reasoning briefly when asked, but default to concise answers."
    },
    {
      "title": "Qwen2.5-Coder 7B",
      "provider": "ollama",
      "model": "qwen2.5-coder:7b",
      "apiBase": "http://localhost:11434",
      "completionOptions": {
        "temperature": 0.3,
        "maxTokens": 4096,
        "topP": 0.9,
        "topK": 20
      },
      "systemMessage": "You are Smart AI, a practical coding assistant. Write clean, modern code following the project's existing conventions. Prefer minimal, targeted changes. Explain reasoning briefly when asked, but default to concise answers."
    },
    {
      "title": "Qwen2.5-Coder 1.5B (Autocomplete)",
      "provider": "ollama",
      "model": "qwen2.5-coder:1.5b",
      "apiBase": "http://localhost:11434",
      "completionOptions": {
        "temperature": 0.2,
        "maxTokens": 256,
        "topP": 0.9
      }
    },
    {
      "title": "Nomic Embed",
      "provider": "ollama",
      "model": "nomic-embed-text",
      "apiBase": "http://localhost:11434"
    }
  ],
  "tabAutocompleteModel": {
    "title": "Qwen2.5-Coder 1.5B (Autocomplete)",
    "provider": "ollama",
    "model": "qwen2.5-coder:1.5b",
    "apiBase": "http://localhost:11434"
  },
  "tabAutocompleteOptions": {
    "disable": false,
    "maxPromptTokens": 1024,
    "debounceDelay": 300,
    "maxSuffixPercentage": 0.2,
    "prefixPercentage": 0.5,
    "useCache": true
  },
  "contextProviders": [
    { "name": "file" },
    { "name": "currentFile" },
    { "name": "open" },
    { "name": "codebase" },
    { "name": "folder" },
    { "name": "diff" },
    { "name": "terminal" },
    { "name": "problems" },
    { "name": "rules" },
    { "name": "docs" }
  ],
  "rules": [
    {
      "name": "Smart AI Copilot Behavior",
      "rule": "You are Smart AI, a practical coding assistant. Write clean, modern code following the project's existing conventions. Prefer minimal, targeted changes. Explain reasoning briefly when asked, but default to concise answers. When editing code, preserve existing style and formatting.",
      "alwaysApply": true
    }
  ],
  "ui": {
    "codeBlockToolbarPosition": "top",
    "displayRawMarkdown": false,
    "showChatScrollbar": true,
    "codeWrap": true
  },
  "analytics": {
    "provider": "null"
  },
  "experimental": {
    "modelRoles": {
      "inlineEdit": "Smart AI Coder",
      "applyCodeBlock": "Smart AI Coder",
      "repoMapFileSelection": "Smart AI Coder"
    }
  }
}
